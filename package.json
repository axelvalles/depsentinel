{
  "name": "depsentinel",
  "version": "0.1.0",
  "description": "JS/TS supply-chain hardening CLI for scan, init, and CI policy gating",
  "type": "module",
  "bin": {
    "depsentinel": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "exports": {
    ".": "./dist/cli.js"
  },
  "files": [
    "dist",
    "docs/security-best-practices.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cac": "^6.7.14"
  },
  "devDependencies": {
    "@types/node": "^22.15.31",
    "typescript": "^5.8.3",
    "vitest": "^2.1.8"
  }
}
