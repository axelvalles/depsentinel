{
  "name": "depsentinel",
  "version": "0.1.0",
  "description": "JS/TS supply-chain hardening CLI for scan, init, and CI policy gating",
  "type": "module",
  "bin": {
    "depsentinel": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "exports": {
    ".": "./dist/cli.js"
  },
  "files": [
    "dist",
    "docs/security-best-practices.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint:lockfile": "lockfile-lint --path pnpm-lock.yaml --type pnpm --allowed-hosts npm --validate-https",
    "sbom": "npx @cyclonedx/cyclonedx-npm --validate > sbom.json"
  },
  "dependencies": {
    "cac": "6.7.14"
  },
  "devDependencies": {
    "@types/node": "22.15.31",
    "lockfile-lint": "4.14.1",
    "typescript": "5.8.3",
    "vitest": "2.1.9"
  },
  "packageManager": "pnpm@11.2.2+sha512.36e6621fad506178936455e70247b8808ef4ec25797a9f437a93281a020484e2607f6a469a22e982987c3dbb8866e3071514ab10a4a1749e06edcd1ec118436f"
}
